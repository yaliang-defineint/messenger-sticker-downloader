{
  "manifest_version": 3,
  "name": "Messenger Sticker Downloader",
  "version": "2.0.0",
  "description": "右鍵下載 Facebook Messenger 聊天室中的貼圖 (支援 GIF 轉檔)",
  "permissions": [
    "contextMenus",
    "storage",
    "offscreen",
    "downloads"
  ],
  "host_permissions": [
    "https://*.facebook.com/*",
    "https://*.messenger.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.facebook.com/*",
        "https://*.messenger.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}