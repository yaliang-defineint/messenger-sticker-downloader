{
  "manifest_version": 3,
  "name": "Messenger Sticker Downloader",
  "version": "1.0",
  "description": "右鍵下載 Facebook Messenger 聊天室中的貼圖！",
  "permissions": [
    "contextMenus",
    "downloads",
    "webRequest"
  ],
  "host_permissions": [
    "https://*.facebook.com/*",
    "https://*.messenger.com/*",
    "https://*.fbcdn.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.facebook.com/*",
        "https://*.messenger.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/download_icon16px.png",
    "48": "icons/download_icon48px.png",
    "128": "icons/download_icon128px.png"
  }
}